+    }
+
     psa_algorithm_t hash_alg = PSA_ALG_SIGN_GET_HASH(alg);
     psa_key_type_t key_type = psa_get_key_type(attributes);
     psa_key_bits_t key_bits = psa_get_key_bits(attributes);
@@ -299,6 +306,12 @@ psa_status_t cc3xx_verify_hash(const psa_key_attributes_t *attributes,
     CC3XX_ASSERT(hash != NULL);
     CC3XX_ASSERT(signature != NULL);
 
+    psa_status_t status = cc3xx_runtime_require_opaque_key(attributes);
+
+    if (status != PSA_SUCCESS) {
+        return status;
+    }
+
     psa_algorithm_t hash_alg = PSA_ALG_SIGN_GET_HASH(alg);
     psa_key_type_t key_type = psa_get_key_type(attributes);
     psa_key_bits_t key_bits = psa_get_key_bits(attributes);
@@ -359,6 +372,12 @@ psa_status_t cc3xx_sign_message(const psa_key_attributes_t *attributes,
     CC3XX_ASSERT(signature != NULL);
     CC3XX_ASSERT(signature_length != NULL);
 
+    psa_status_t status = cc3xx_runtime_require_opaque_key(attributes);
+
+    if (status != PSA_SUCCESS) {
+        return status;
+    }
+
     psa_algorithm_t hash_alg = PSA_ALG_SIGN_GET_HASH(alg);
     psa_key_type_t key_type = psa_get_key_type(attributes);
     psa_key_bits_t key_bits = psa_get_key_bits(attributes);
@@ -414,6 +433,12 @@ psa_status_t cc3xx_verify_message(const psa_key_attributes_t *attributes,
     CC3XX_ASSERT(input != NULL);
     CC3XX_ASSERT(signature != NULL);
 
+    psa_status_t status = cc3xx_runtime_require_opaque_key(attributes);
+
+    if (status != PSA_SUCCESS) {
+        return status;
+    }
+
     psa_algorithm_t hash_alg = PSA_ALG_SIGN_GET_HASH(alg);
     psa_key_type_t key_type = psa_get_key_type(attributes);
     psa_key_bits_t key_bits = psa_get_key_bits(attributes);
diff --git a/vendor/arm/cc3xx/psa_driver_api/src/cc3xx_psa_key_agreement.c b/vendor/arm/cc3xx/psa_driver_api/src/cc3xx_psa_key_agreement.c
index f49bb47..8f4cfea 100644
--- a/vendor/arm/cc3xx/psa_driver_api/src/cc3xx_psa_key_agreement.c
+++ b/vendor/arm/cc3xx/psa_driver_api/src/cc3xx_psa_key_agreement.c
@@ -16,6 +16,7 @@
 #include <string.h>
 
 #include "cc3xx_psa_key_agreement.h"
+#include "cc3xx_psa_runtime_fallback.h"
 #include "cc3xx_misc.h"
 
 #include "cc3xx_stdlib.h"
@@ -49,6 +50,11 @@ psa_status_t cc3xx_key_agreement(
     CC3XX_ASSERT(output_length != NULL);
 
     psa_status_t status = PSA_ERROR_CORRUPTION_DETECTED;
+    psa_status_t opaque_status = cc3xx_runtime_require_opaque_key(attributes);
+
+    if (opaque_status != PSA_SUCCESS) {
+        return opaque_status;
+    }
 
